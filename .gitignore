# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]serSettings/
[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated Crash Reports
sysinfo.txt

# Burst debug information
*_BurstDebugInformation_DoNotShip/

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Visual Studio / Rider
.vs/
.idea/
*.csproj
*.sln
*.slnx
*.sln.DotSettings.user
*.pidb
*.suo
*.user
*.userprefs
*.unityproj

# OS files
.DS_Store
Thumbs.db

# Mono crash dumps
mono_crash.*

# UTMP
.utmp/

# Secrets
Assets/StreamingAssets/secrets.json

# Claude Code local config
CLAUDE.local.md

# Superpowers / Brainstorming workspace artifacts
.superpowers/

# Headless test runner output (Tools/run-tests-headless.sh)
Tools/test-output/

# n8n reference templates (downloaded community/marketplace workflows, not part of the app)
Tools/n8n/reference/

# n8n derived dev-config workflows (generated by apply-dev-config.py)
Tools/n8n/workflows-local/
