{
  "name": "Delete Bot Files",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "DeleteBotFiles",
        "responseMode": "responseNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        0,
        0
