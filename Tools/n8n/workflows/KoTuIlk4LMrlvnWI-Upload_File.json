        "jsCode": "// Function to remove all null bytes from a string\nfunction removeNullBytes(str) {\n  return str.replace(/\\0/g, ''); \n}\n\nconst outputItems = [];\n\nfor (const item of $input.all()) {\n  // *** Corrected line: Define the exact field name as a string literal ***\n  const fieldName = 'text'; \n\n  if (item.json[fieldName] && typeof item.json[fieldName] === 'string') {\n    // Sanitize the data in place\n    item.json[fieldName] = removeNullBytes(item.json[fieldName]);\n  }\n  \n  outputItems.push(item);\n}\n\nreturn outputItems;\n"
      },
