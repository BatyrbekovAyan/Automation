    {
      "parameters": {
        "jsCode": "function decodeMimeQP(encodedString) {\n    // Декодирование из формата =?UTF-8?Q?...?=\n    if (encodedString.startsWith('=?utf-8?Q?') && encodedString.endsWith('?=')) {\n        let content = encodedString.substring(10, encodedString.length - 2);\n        // Замена '_', используемого вместо пробела\n        content = content.replace(/_/g, ' ');\n        // Декодирование шестнадцатеричных последовательностей (=D0=A3)\n        return decodeURIComponent(content.replace(/=([0-9A-F]{2})/g, '%$1'));\n    }\n    return encodedString; // Возвращаем исходную строку, если формат не QP\n}\n\n// Access the first item from the input using $input.first()\nconst firstItem = $input.first();\n\n// Check if binary data exists within the first item\nif (firstItem && firstItem.binary && firstItem.binary.data && firstItem.binary.data.fileName) {\n    const originalFileName = firstItem.binary.data.fileName;\n    const decodedFileName = decodeMimeQP(originalFileName);\n    \n    // Обновляем объект бинарных данных новым именем файла\n    firstItem.binary.data.fileName = decodedFileName;\n}\n\n// Return the modified input items\nreturn $input.all();"
      },
